# Gemini API Key
VITE_GEMINI_API_KEY=your-gemini-key-here

# Socket Server URL (only needed for production / different network)
# Leave EMPTY if running locally on same WiFi (vite proxy handles it)
# Set to your laptop's IP for cross-network access, e.g.:
# VITE_SOCKET_URL=http://192.168.1.5:3001
VITE_SOCKET_URL=
